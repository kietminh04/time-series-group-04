profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent git from tracking it.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if the platform is not identical it may cause dependency resolution issues.
#   Also, it is a binary file.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions, but may be committed depending on workflow.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact versions, but may be committed depending on workflow.
#pdm.lock

# PEP 582; project local dependencies [pyproject.toml]
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

